{
  "name": "create-mcp-server",
  "version": "0.1.0",
  "description": "A CLI tool that generates ready-to-run MCP servers.",
  "type": "module",
  "bin": {
    "create-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\" \"public/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"public/**/*.{js,css,html}\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "generator",
    "scaffold"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BurhanHussain1/create-mcp-server.git"
  },
  "homepage": "https://github.com/BurhanHussain1/create-mcp-server#readme",
  "bugs": "https://github.com/BurhanHussain1/create-mcp-server/issues",
  "author": "Burhan Hussain",
  "engines": {
    "node": ">=18"
  },
  "files": ["dist", "templates", "public", "examples"],
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "commander": "^15.0.0",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
